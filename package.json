{
  "name": "@e4a/pg-js",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": false,
  "description": "Browser SDK for PostGuard — end-to-end encrypted file sharing with identity-based encryption",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/encryption4all/postguard-js.git"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@e4a/pg-wasm": "^0.5.5",
    "@transcend-io/conflux": "^6.1.3"
  },
  "peerDependencies": {
    "@privacybydesign/yivi-core": "^1.0.0-beta.1",
    "@privacybydesign/yivi-web": "^1.0.0-beta.1",
    "@privacybydesign/yivi-client": "^1.0.0-beta.1"
  },
  "peerDependenciesMeta": {
    "@privacybydesign/yivi-core": { "optional": true },
    "@privacybydesign/yivi-web": { "optional": true },
    "@privacybydesign/yivi-client": { "optional": true }
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.9.0"
  },
  "keywords": [
    "postguard",
    "ibe",
    "encryption",
    "identity-based-encryption",
    "yivi",
    "irma"
  ]
}
